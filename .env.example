# OpenAI / Compatible LLM API
# Copy this file to .env and fill in your values. NEVER commit .env.
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1   # Change for Azure/local LLMs (LM Studio, Ollama, etc.)
OPENAI_MODEL=gpt-4o                          # Model to use for categorization

# Categorization Settings
BATCH_SIZE=0             # 0 = unlimited: send all bookmarks in one request
MAX_RETRIES=3            # Retry failed AI calls
CONFIDENCE_THRESHOLD=0.7 # Min confidence score to auto-accept category

# Output
OUTPUT_DIR=./output
BACKUP_DIR=./backups
LOG_LEVEL=info           # debug | info | warn | error
